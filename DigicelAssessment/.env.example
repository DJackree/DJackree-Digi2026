# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — use host `db` when Django runs inside Docker Compose `web`.
# Use `localhost` when Django runs on your machine with `docker compose up -d db` only.
POSTGRES_DB=telecom_portal
POSTGRES_USER=telecom_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Groq (used by chatbot in a later phase; keep in one env file)
GROQ_API_KEY=
